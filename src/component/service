const API_BASE_URL = "http://localhost:8080/api";

export const getMemoryData = async () => {
  try {
    const response = await fetch(`${API_BASE_URL}/memory`);

    if (!response.ok) {
      throw new Error("Failed to fetch memory data");
    }

    return await response.json();
  } catch (error) {
    console.error("Error fetching memory data:", error);

    // Dummy data for development
    return {
      usedMemory: 512,
      freeMemory: 1024,
      totalMemory: 1536,
      maxMemory: 2048,
      leakStatus: "Normal",
    };
  }
};

export default getMemoryData;
